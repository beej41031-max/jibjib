# ---- Supabase ----
# Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# ---- Seeding only (server-side, NEVER commit / never NEXT_PUBLIC) ----
# Used once by `npm run seed` to write rows to Supabase.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# Optional: how close (metres) a user must be to bag a cafe. Default 200.
NEXT_PUBLIC_BAG_RADIUS_M=200
